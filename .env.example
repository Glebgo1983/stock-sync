# Скопируйте этот файл в .env.local и заполните реальными значениями.
# .env.local в git не попадает (см. .gitignore).

# Токен mpFit (Bearer). Выдаётся через Telegram-поддержку mpFit.
MPFIT_TOKEN=

# Доступ к inSales REST API (Basic Auth). Создаётся в приложении inSales
# (Настройки -> Приложения -> своё приложение) как пара api_key/password.
INSALES_USERNAME=
INSALES_PASSWORD=

# Домен магазина inSales, например myshop-dbn10.myinsales.ru
INSALES_SHOP_DOMAIN=

# Redis для кэша статусов заказов (используется /api/update, /api/create)
REDIS_URL=

# Секрет для защиты /api/sync-stock. Если переменная называется именно
# CRON_SECRET, Vercel Cron Jobs автоматически подставит её в заголовок
# Authorization: Bearer $CRON_SECRET при вызове по расписанию.
# Для ручных проверок и внешнего cron-сервиса передавайте тот же заголовок вручную.
CRON_SECRET=

# CDEK / Почта России — используются для получения трек-номеров (не относится
# к синхронизации остатков, но требуются существующему коду заказов).
CDEK_CLIENT=
CDEK_SECRET=
POCHTA_APP_AUTH_TOKEN=
POCHTA_CLIENT_AUTH_KEY=
