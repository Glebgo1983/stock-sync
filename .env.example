# Скопируйте этот файл в .env.local и заполните реальными значениями.
# .env.local в git не попадает (см. .gitignore).

# Токен mpFit (Bearer). Выдаётся через Telegram-поддержку mpFit.
MPFIT_TOKEN=

# Доступ к inSales REST API (Basic Auth). Создаётся в приложении inSales
# (Настройки -> Приложения -> своё приложение) как пара api_key/password.
INSALES_USERNAME=
INSALES_PASSWORD=

# Домен магазина inSales, например myshop-dbn10.myinsales.ru
INSALES_SHOP_DOMAIN=

# Redis для кэша статусов заказов (/api/update, /api/create), а также для
# журнала синхронизации остатков и таблицы соответствий mpFit<->inSales
# (/api/sync-stock, /api/sync-log)
REDIS_URL=

# Список исключённых из синхронизации остатков товаров — через запятую, без
# изменения кода. Не обязательны одновременно, можно использовать любой один.
# По артикулу/sku (как в inSales, регистр и пробелы важны после trim):
SYNC_EXCLUDED_SKUS=
# По внутреннему ID товара mpFit — переживает переименование артикула:
SYNC_EXCLUDED_MPFIT_IDS=

# TTL блокировки, защищающей от параллельных запусков /api/sync-stock, в
# секундах. Необязательно — по умолчанию 600 (10 минут). Увеличьте, если
# полная синхронизация каталога стабильно занимает больше этого времени.
SYNC_LOCK_TTL_SECONDS=

# Секрет для /api/stock-webhook (вебхук остатков от mpFit). Сгенерируйте
# сами (например: python -c "import secrets; print(secrets.token_urlsafe(32))")
# и передайте mpFit тем способом, который поддерживает их UI настройки
# вебхука — либо как query-параметр в самом URL:
#   https://<ваш-проект>.vercel.app/api/stock-webhook?secret=<значение>
# либо, если у них есть кастомные заголовки, как
#   Authorization: Bearer <значение>
MPFIT_WEBHOOK_SECRET=

# Сколько страниц ленты mpFit /cim-codes сканировать за один прогон
# /api/sync-kiz (по 200 кодов на страницу). Необязательно — по умолчанию 50
# (10 000 кодов). Лента не фильтруется по заказу (подтверждено эмпирически),
# поэтому сканируется с начала каждый раз; лимит — просто защита от таймаута
# на serverless по мере роста истории кодов, не чекпоинт.
SYNC_KIZ_MAX_PAGES=

# ID кастомного поля заказа "КИЗ" в inSales (Настройки -> Параметры заказов).
# Значение по умолчанию соответствует полю, уже созданному в этом магазине
# 2026-07-21. Переопределите, только если поле пересоздавалось и получило
# другой id.
INSALES_KIZ_FIELD_ID=

# Секрет для защиты /api/sync-stock, /api/sync-log и /api/sync-kiz. Если
# переменная называется именно CRON_SECRET, Vercel Cron Jobs автоматически
# подставит её в заголовок Authorization: Bearer $CRON_SECRET при вызове по
# расписанию. Для ручных проверок и внешнего cron-сервиса передавайте тот же
# заголовок вручную.
CRON_SECRET=

# CDEK / Почта России — используются для получения трек-номеров (не относится
# к синхронизации остатков, но требуются существующему коду заказов).
CDEK_CLIENT=
CDEK_SECRET=
POCHTA_APP_AUTH_TOKEN=
POCHTA_CLIENT_AUTH_KEY=
